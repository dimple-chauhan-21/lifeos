# Copy to infra/.env and fill in real values before running `docker compose up`.
# Every variable listed here is required — the API fails fast at startup if any is missing.

# --- PostgreSQL ---
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=changeme-postgres-password
POSTGRES_DB=lifeos

# --- Redis ---
REDIS_PASSWORD=changeme-redis-password

# --- MinIO ---
MINIO_ROOT_USER=lifeos
MINIO_ROOT_PASSWORD=changeme-minio-password
MINIO_BUCKET_NAME=lifeos-attachments
